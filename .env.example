# ============================================
# CONFIGURACIÓN TEMPORALMENTE DESHABILITADA
# ============================================
# Las credenciales del proyecto anterior han sido desconectadas.
# Cuando tengas las nuevas credenciales del nuevo proyecto, 
# crea un archivo .env y configúralas aquí.

# Supabase Configuration (NUEVO PROYECTO - Por configurar)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Chatwoot Configuration (NUEVO PROYECTO - Por configurar)
# Nota: Configurar la nueva URL de Chatwoot cuando esté disponible
VITE_CHATWOOT_BASE_URL=
VITE_CHATWOOT_API_TOKEN=

# OpenAI para Supabase Edge Functions
# No agregar estas variables como VITE_* ni exponerlas en frontend.
# Configurarlas con:
# supabase secrets set OPENAI_API_KEY=tu_api_key
# npx supabase secrets set OPENAI_REPORT_MODEL=gpt-5.4-mini --project-ref oqmjnvbbznzsnecvswex
# npx supabase secrets set OPENAI_REPORT_REASONING_EFFORT=low --project-ref oqmjnvbbznzsnecvswex
# Overrides opcionales:
# OPENAI_REPORT_MODEL_PDF=gpt-5.4
# OPENAI_REPORT_MODEL_TABLE=gpt-5.4-mini
# OPENAI_REPORT_MODEL_DAILY_OPERATIONS_EXCEL=gpt-5.4-mini

# ============================================
# CREDENCIALES ANTERIORES (DESHABILITADAS)
# ============================================
# VITE_SUPABASE_URL=https://vbcswxtioavfywxplkus.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGc...
# VITE_CHATWOOT_BASE_URL=/chatwoot-api/api/v1/accounts/1
# VITE_CHATWOOT_API_TOKEN=Zz4kfVeARYpjnVfiDE7SyobG

